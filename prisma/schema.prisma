generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  reader
  writer
  editor
  admin
}

model User {                                     
  userId      Int     @id @default(autoincrement())
  name        String
  email       String  @unique
  password    String
  role        Role
  dateOfBirth DateTime
}

model News { 
  newsId    Int     @id @default(autoincrement()) 
  title     String
  content   String
  author    String 
  thumbnail String
  published Boolean @default(false)
} 